{
  "name": "street-coin-runner-152",
  "version": "1.0.0",
  "description": "Street Coin Runner 152 - An arcade endless runner desktop game",
  "main": "main.js",
  "author": "Street Coin Runner Team",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "build:portable": "electron-builder --win portable",
    "build:installer": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.streetcoinrunner.app",
    "productName": "Street Coin Runner 152",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "StreetCoinRunner152-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Street Coin Runner 152"
    },
    "portable": {
      "artifactName": "StreetCoinRunner152-Portable-${version}.exe"
    }
  }
}
